        <mxCell id="16" value="Система кредитного скоринга&#xa;(Python Flask + PostgreSQL)" style="shape=rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="10"><mxGeometry x="350" y="260" width="280" height="100" as="geometry"/></mxCell>
